[Argument]

[General]

bypass-tun =

skip-proxy =

real-ip =

dns-server =

[rule]

[rewrite]
# TMDB 跳转
TMDB-Forward = type=http-response, pattern=^https?:\/\/.+\.themoviedb\.org\/(?:movie|tv)\/\d+, requires-body=1, timeout=30, script-path=https://你的脚本地址/forward-jump.js, tag=Forward-TMDB

# IMDb 跳转
IMDb-Forward = type=http-response, pattern=^https?:\/\/.+\.imdb\.com\/title\/tt\d+, requires-body=1, timeout=30, script-path=https://你的脚本地址/forward-jump.js, tag=Forward-IMDb

# 豆瓣跳转
Douban-Forward = type=http-response, pattern=^https?:\/\/.+\.douban\.com\/subject\/\d+, requires-body=1, timeout=30, script-path=https://你的脚本地址/forward-jump.js, tag=Forward-Douban

[host]

[script]

[mitm]
hostname = *.themoviedb.org, *.imdb.com, *.douban.com
