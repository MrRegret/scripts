[Argument]

[General]

bypass-tun =

skip-proxy =

real-ip =

dns-server =

[rule]

[rewrite]

[host]

[script]
http-response ^https?:\/\/.+\.themoviedb\.org\/(?:movie|tv)\/\d+ script-path=https://raw.githubusercontent.com/MrRegret/scripts/refs/heads/main/jumptoforward.js, requires-body=true, tag=Forward-TMDB
http-response ^https?:\/\/.+\.imdb\.com\/title\/tt\d+ script-path=https://raw.githubusercontent.com/MrRegret/scripts/refs/heads/main/jumptoforward.js, requires-body=true, tag=Forward-IMDb
http-response ^https?:\/\/(?:movie|m)\.douban\.com\/(?:movie\/)?subject\/\d+ script-path=https://raw.githubusercontent.com/MrRegret/scripts/refs/heads/main/jumptoforward.js, requires-body=true, tag=Forward-Douban

[mitm]
hostname = *.themoviedb.org, *.imdb.com, *.douban.com
